# Optional: override the deployed AI proxy URL for non-default environments.
# The OpenRouter key must stay server-side in Firebase Secret Manager as
# OPENROUTER_API_KEY. Do not put OpenRouter keys in VITE_* variables.
# VITE_AI_PROXY_URL=https://us-central1-gentle-badass.cloudfunctions.net/aiProxy
