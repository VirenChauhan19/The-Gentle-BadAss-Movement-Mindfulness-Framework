rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and write their own journal entries
    match /users/{userId}/journal/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Each user can read and write their own config (profile, coach data)
    match /users/{userId}/config/{configId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin (Viren) can read and delete any user's journal entries
    match /{path=**}/journal/{entryId} {
      allow read, delete: if request.auth != null
                          && request.auth.token.email == 'chauhan.viren08@gmail.com';
    }

    // Admin can read, write and delete any user's config documents
    // (covers tombstone writes for deleted accounts too)
    match /users/{userId}/config/{configId} {
      allow read, write, delete: if request.auth != null
                                 && request.auth.token.email == 'chauhan.viren08@gmail.com';
    }

    // Admin can edit any user's running coach plan and write remarks
    match /users/{userId}/config/coach {
      allow write: if request.auth != null
                   && request.auth.token.email == 'chauhan.viren08@gmail.com';
    }

    match /users/{userId}/config/adminRemarks {
      allow write: if request.auth != null
                   && request.auth.token.email == 'chauhan.viren08@gmail.com';
    }
  }
}
