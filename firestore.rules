rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin identity ───────────────────────────────────────────────────────
    // Founding "owner" admins — always admins, can never be locked out. Also
    // hardcoded in the app (DEFAULT_ADMIN_EMAILS).
    function isDefaultAdmin() {
      return request.auth != null
             && request.auth.token.email in [
               'chauhan.viren08@gmail.com',
               'drrajatchauhan@gmail.com'
             ];
    }

    // An admin is a founder OR has a doc in the `admins` collection keyed by
    // their (verified) email. Single source of truth shared with the app.
    function isAdmin() {
      return isDefaultAdmin()
             || (request.auth != null
                 && request.auth.token.email != null
                 && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // True when the caller owns this uid (and has a verified account).
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Dynamic admin list ───────────────────────────────────────────────────
    // A signed-in user may read ONLY their own entry (to learn if they're an
    // admin). Only admins can list everyone or grant/revoke access, and a new
    // admin doc must be keyed by the email it names (no spoofing).
    match /admins/{adminEmail} {
      allow get:    if request.auth != null
                    && (request.auth.token.email == adminEmail || isAdmin());
      allow list:   if isAdmin();
      allow create, update: if isAdmin()
                    && request.resource.data.email == adminEmail
                    && request.resource.data.keys().hasOnly(['email', 'addedBy', 'addedAt']);
      allow delete: if isAdmin();
    }

    // ── A user's own data ────────────────────────────────────────────────────
    // Journal entries and config (profile, coach, remarks, tombstone) are
    // private to the owner. No cross-user access for normal users.
    match /users/{userId}/journal/{entryId} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/config/{configId} {
      allow read, write: if isOwner(userId);
    }

    // ── Admin access to user data ────────────────────────────────────────────
    // Admins can read any journal entry (collection-group) and read/write/delete
    // any config doc (remarks, plan edits, profile fixes, tombstones).
    match /{path=**}/journal/{entryId} {
      allow read, delete: if isAdmin();
    }
    match /users/{userId}/config/{configId} {
      allow read, write, delete: if isAdmin();
    }

    // ── Member ↔ admin messaging ─────────────────────────────────────────────
    // A two-way conversation thread per user. The user reads their own thread,
    // posts messages labelled 'user' (never 'admin'), and may flip admin
    // messages to read (readByUser only). Admins read every thread (directly and
    // via collection-group), reply, mark read, and moderate. Message text is
    // size-bounded; keys are fixed so the shape can't be polluted.
    match /users/{userId}/messages/{messageId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId)
                        && request.resource.data.from == 'user'
                        && request.resource.data.authorUid == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 4000
                        && request.resource.data.readByUser == true
                        && request.resource.data.readByAdmin == false
                        && request.resource.data.keys().hasOnly([
                             'from', 'authorUid', 'authorName', 'authorEmail',
                             'text', 'createdAt', 'ts', 'readByUser', 'readByAdmin'
                           ]))
                    || (isAdmin()
                        && request.resource.data.from == 'admin'
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 4000);
      // The user may only toggle readByUser; admins can update anything.
      allow update: if (isOwner(userId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByUser']))
                    || isAdmin();
      allow delete: if isAdmin();
    }
    // Admin collection-group read of every thread (unread badges + dashboard).
    match /{path=**}/messages/{messageId} {
      allow read: if isAdmin();
    }

    // ── Announcements ─────────────────────────────────────────────────────────
    // One-to-many notices. Any signed-in member may read the global feed; only
    // admins post or remove them. Text is size-bounded.
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 4000;
      allow delete: if isAdmin();
    }

    // ── Audit log ────────────────────────────────────────────────────────────
    // Append-only. A user may create an event ONLY for themselves, with their
    // verified identity, a fixed set of fields, sane sizes, and may NOT label
    // themselves 'admin' unless they actually are one. No edits, ever. Reading
    // the log is admin-only (it can reference other users).
    match /activity/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.actorUid == request.auth.uid
                    && request.resource.data.actorEmail == request.auth.token.email
                    && request.resource.data.keys().hasOnly([
                         'actorUid', 'actorEmail', 'actorName', 'actorRole',
                         'action', 'targetUid', 'targetName', 'summary',
                         'details', 'isoTs', 'ts'
                       ])
                    && request.resource.data.action is string
                    && request.resource.data.action.size() <= 100
                    && request.resource.data.summary is string
                    && request.resource.data.summary.size() <= 1000
                    && request.resource.data.actorName.size() <= 200
                    && request.resource.data.targetName.size() <= 200
                    && (request.resource.data.actorRole == 'user' || isAdmin());
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // ── Sheet-sync plumbing ──────────────────────────────────────────────────
    // Admins can ask the Cloud Function to rebuild the Google Sheet (create a
    // command) and watch its progress (read). Status updates are written by
    // the function via the Admin SDK, never from browsers.
    match /adminCommands/{commandId} {
      allow create: if isAdmin()
                    && request.resource.data.keys().hasOnly(['action', 'requestedBy', 'requestedAt'])
                    && request.resource.data.action is string
                    && request.resource.data.action.size() <= 100
                    && request.resource.data.requestedBy == request.auth.token.email;
      allow read:   if isAdmin();
      allow update, delete: if false;
    }

    // Sync state written by the Cloud Function; the dashboard reads it to show
    // "last synced" info for the Google Sheet mirror.
    match /syncState/{stateId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Everything else is denied by default.
  }
}
