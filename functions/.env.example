# Copy to functions/.env and fill in. Firebase loads this at deploy time.

# The Google Sheet to mirror activity into. Get the id from the sheet URL:
# https://docs.google.com/spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=

# Tab/worksheet name inside that sheet (created by you; default below).
GOOGLE_SHEET_TAB=Activity Log

# The service account the function runs AS. Set this to an account you can see
# in IAM today so you can share the Sheet with it right away. The Firebase Admin
# SDK account always exists:
FUNCTION_SERVICE_ACCOUNT=firebase-adminsdk-fbsvc@gentle-badass.iam.gserviceaccount.com

# Optional: deploy region (defaults to us-central1).
# FUNCTIONS_REGION=us-central1
